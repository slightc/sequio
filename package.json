{
  "name": "video-editor-canvas",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for video-editor-canvas: a PixiJS-based video-editor runtime (engine), its server-side renderer (server) and a reference multi-track editor (studio).",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -F @video-editor-canvas/engine build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:watch": "pnpm -F @video-editor-canvas/engine test:watch",
    "dev": "pnpm -F @video-editor-canvas/studio dev",
    "dev:engine": "pnpm -F @video-editor-canvas/engine dev",
    "dev:server": "pnpm -F @video-editor-canvas/server dev",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "verify:decode": "pnpm -F @video-editor-canvas/engine verify:decode",
    "verify:render": "pnpm -F @video-editor-canvas/engine verify:render",
    "verify:clips": "pnpm -F @video-editor-canvas/engine verify:clips",
    "verify:font": "pnpm -F @video-editor-canvas/engine verify:font",
    "verify:audio": "pnpm -F @video-editor-canvas/engine verify:audio",
    "verify:effects": "pnpm -F @video-editor-canvas/engine verify:effects",
    "verify:export": "pnpm -F @video-editor-canvas/engine verify:export",
    "verify:origin": "pnpm -F @video-editor-canvas/engine verify:origin",
    "verify:video-import": "pnpm -F @video-editor-canvas/studio verify:video-import",
    "verify:editor-export": "pnpm -F @video-editor-canvas/studio verify:editor-export",
    "verify:editor-audio": "pnpm -F @video-editor-canvas/studio verify:editor-audio",
    "verify:ssr": "pnpm -F @video-editor-canvas/server verify:ssr",
    "verify:ssr-node": "pnpm -F @video-editor-canvas/server verify:ssr-node",
    "verify:ssr-node-audio": "pnpm -F @video-editor-canvas/server verify:ssr-node-audio",
    "verify:ssr-node-font": "pnpm -F @video-editor-canvas/server verify:ssr-node-font",
    "verify:ssr-node-media": "pnpm -F @video-editor-canvas/server verify:ssr-node-media",
    "ssr:render": "pnpm -F @video-editor-canvas/server ssr:render",
    "ssr:render-node": "pnpm -F @video-editor-canvas/server ssr:render-node"
  },
  "keywords": [
    "pixijs",
    "video-editor",
    "webcodecs",
    "compositor",
    "timeline",
    "canvas",
    "monorepo"
  ],
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.0",
    "puppeteer": "^25.2.1",
    "tsx": "^4.22.5",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.0"
  }
}
