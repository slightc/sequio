{
  "name": "@sequio/cli",
  "version": "0.0.0",
  "description": "The sequio command-line: `sequio render <file>` encodes a composition to video (headless Chrome), `sequio preview <file>` serves a live in-browser preview (with --watch).",
  "type": "module",
  "license": "MIT",
  "bin": {
    "sequio": "./bin/sequio.js"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:cli": "tsx scripts/verify-cli.ts"
  },
  "keywords": [
    "cli",
    "video-editor",
    "render",
    "preview",
    "pixijs"
  ],
  "dependencies": {
    "@sequio/engine": "workspace:*",
    "@sequio/runtime": "workspace:*",
    "@sequio/server": "workspace:*"
  }
}
