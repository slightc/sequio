{
  "name": "@sequio/engine",
  "version": "0.1.1",
  "description": "A command-style object-graph engine for building video editors on top of PixiJS. Provides the runtime (decode / composite / audio / export); persistence, schema, undo, collaboration and UI are left to the consumer.",
  "type": "module",
  "license": "MIT",
  "author": "slightc",
  "homepage": "https://sequio-demo.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slightc/sequio.git",
    "directory": "packages/engine"
  },
  "bugs": {
    "url": "https://github.com/slightc/sequio/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "prepublishOnly": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:decode": "node scripts/verify-page.cjs example/decode-test.html __DECODE_TEST__ \"VideoSource decode\"",
    "verify:render": "node scripts/verify-page.cjs example/multitrack-test.html __RENDER_TEST__ \"multi-track render\"",
    "verify:clips": "node scripts/verify-page.cjs example/clips-test.html __CLIPS_TEST__ \"image/text/shape clips\"",
    "verify:text-anim": "node scripts/verify-page.cjs example/text-anim-test.html __TEXT_ANIM_TEST__ \"text motion effects\"",
    "verify:gsap": "node scripts/verify-page.cjs example/gsap-demo.html __GSAP_TEST__ \"gsap-driven clips\"",
    "verify:font": "node scripts/verify-page.cjs example/font-test.html __FONT_TEST__ \"google font\"",
    "verify:audio": "node scripts/verify-page.cjs example/audio-test.html __AUDIO_TEST__ \"audio engine\"",
    "verify:reverse": "node scripts/verify-page.cjs example/reverse-test.html __REVERSE_TEST__ \"reverse playback\"",
    "verify:reverse-decode": "node scripts/verify-page.cjs example/reverse-decode-test.html __REVERSE_DECODE_TEST__ \"reverse decode\"",
    "verify:effects": "node scripts/verify-page.cjs example/effects-test.html __EFFECTS_TEST__ \"effects & transitions\"",
    "verify:export": "node scripts/verify-page.cjs example/export-test.html __EXPORT_TEST__ \"exporter\"",
    "verify:origin": "node scripts/verify-page.cjs example/origin-test.html __ORIGIN_TEST__ \"compositor origin\"",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "pixijs",
    "video-editor",
    "webcodecs",
    "compositor",
    "timeline",
    "canvas"
  ],
  "dependencies": {
    "mediabunny": "^1.49.0",
    "pixi.js": "^8.6.0"
  },
  "devDependencies": {
    "gsap": "^3.12.0"
  }
}
