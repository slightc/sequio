{
  "name": "@sequio/server",
  "version": "0.1.2",
  "description": "The server-side render environment for sequio: `serverEnv`, a pure-Node (PixiJS WebGPU / Dawn) bootstrap that runs the engine's render core outside a browser. The TimelineSpec protocol + RPC live in @sequio/headless; the code-bundle render helpers live in @sequio/cli.",
  "type": "module",
  "license": "MIT",
  "author": "slightc",
  "homepage": "https://sequio-demo.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slightc/sequio.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/slightc/sequio/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepublishOnly": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "server-side-rendering",
    "pixijs",
    "webgpu",
    "video",
    "headless"
  ],
  "dependencies": {
    "@sequio/engine": "workspace:^",
    "mediabunny": "^1.49.0",
    "pixi.js": "^8.6.0"
  },
  "optionalDependencies": {
    "@mediabunny/server": "^1.50.4",
    "@napi-rs/canvas": "^1.0.2",
    "jsdom": "^29.1.1",
    "node-web-audio-api": "^2.0.0",
    "webgpu": "^0.4.0"
  }
}
