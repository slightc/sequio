{
  // Shared compiler options for every workspace package. Each package's own
  // tsconfig extends this and sets its `include`. Path aliases below let the
  // consumer packages (server / studio) resolve the engine straight from
  // source, so `pnpm typecheck` never needs a prior `pnpm build`.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["vite/client", "vitest/globals", "node"],
    "strict": true,
    // Relaxed while the SDK is a skeleton: many fields are stored for
    // milestones that aren't implemented yet. Re-enable once stubs are filled.
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@sequio/engine": ["packages/engine/src/index.ts"],
      "@sequio/server": ["packages/server/src/index.ts"],
      "@sequio/runtime": ["packages/runtime/src/index.ts"],
      "@sequio/runtime/node-fs": ["packages/runtime/src/node-fs.ts"],
      "@sequio/cli": ["packages/cli/src/index.ts"]
    }
  }
}
